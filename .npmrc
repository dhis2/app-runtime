# Workaround for npm workspace resolution during `@dhis2/cli-utils release`.
#
# The release runs `@semantic-release/npm`, which execs `npm version <v>` with
# its cwd inside each workspace member dir (e.g. ./runtime). Run from a member
# dir of a `workspaces` monorepo, npm bumps the version and then, by default,
# reifies the entire workspace tree to keep node_modules in sync. That reify
# resolves the `@dhis2/app-runtime@file:runtime` self-edge relative to the cwd
# instead of the workspace root and crashes the publish step -- as ENOENT on
# runtime/runtime/package.json, or (once deps are pinned) "Cannot read
# properties of null (reading 'matches')".
#
# workspaces-update=false stops `npm version` from doing that post-bump reify,
# so it just writes the new version and exits. package-lock=false is
# against any lockfile-driven reify. Both are safe here: installs go
# through yarn, there is no committed package-lock.json, and the release only
# needs version bumps + publish, not a node_modules update.
workspaces-update=false
package-lock=false
