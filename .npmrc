# Disable package-lock maintenance during release.
#
# `@dhis2/cli-utils release` (via @semantic-release/npm) runs `npm version`
# with its cwd set inside each workspace member dir (e.g. ./runtime). Run from a
# member dir, npm auto-targets the workspace and reifies the tree, resolving the
# `@dhis2/app-runtime@file:runtime` self-edge relative to the cwd instead of the
# workspace root -> looks for runtime/runtime/package.json -> ENOENT -> publish
# fails with exit code 254.
#
# Setting package-lock=false means npm has no lockfile to keep in sync, so it
# skips that reify and just writes the new version into package.json in place.
# Safe here: there is no committed package-lock.json and installs use yarn.
package-lock=false
